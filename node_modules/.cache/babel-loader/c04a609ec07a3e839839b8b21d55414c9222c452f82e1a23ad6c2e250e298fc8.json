a","projectId","_hoisted_5","firestoreStatus"],"sources":["/home/felipe/Documentos/ProjetosVue/ControleDeSom/src/App.vue"],"sourcesContent":["<template>\n  <main class=\"app-shell\">\n    <section class=\"hero-card\">\n      <span class=\"eyebrow\">Controle de Som</span>\n      <h1>Vue conectado ao Firebase</h1>\n      <p class=\"description\">\n        O projeto já está configurado para usar o Firebase e o Cloud Firestore.\n        Agora você pode começar a criar suas coleções, leituras e gravações.\n      </p>\n\n      <div class=\"status-grid\">\n        <article class=\"status-item\">\n          <span class=\"label\">Projeto</span>\n          <strong>{{ projectId }}</strong>\n        </article>\n\n        <article class=\"status-item\">\n          <span class=\"label\">Firestore</span>\n          <strong>{{ firestoreStatus }}</strong>\n        </article>\n      </div>\n\n      <p class=\"hint\">\n        Arquivo pronto para uso: <code>src/firebase.js</code>\n      </p>\n    </section>\n  </main>\n</template>\n\n<script>\nimport { db, firebaseConfig } from './firebase'\n\nexport default {\n  name: 'App',\n  data() {\n    return {\n      projectId: firebaseConfig.projectId,\n      firestoreStatus: db ? 'Inicializado' : 'Indisponivel'\n    }\n  }\n}\n</script>\n\n<style>\n:root {\n  color-scheme: light;\n  --bg-start: #f4efe6;\n  --bg-end: #dbe7f3;\n  --card: rgba(255, 255, 255, 0.78);\n  --border: rgba(30, 41, 59, 0.12);\n  --text: #1f2937;\n  --muted: #526072;\n  --accent: #c96f38;\n  --shadow: 0 24px 60px rgba(31, 41, 55, 0.16);\n}\n\n* {\n  box-sizing: border-box;\n}\n\nbody {\n  margin: 0;\n  font-family: \"Trebuchet MS\", \"Segoe UI\", sans-serif;\n  color: var(--text);\n  background:\n    radial-gradient(circle at top, rgba(201, 111, 56, 0.24), transparent 30%),\n    linear-gradient(135deg, var(--bg-start), var(--bg-end));\n}\n\n#app {\n  min-height: 100vh;\n}\n\n.app-shell {\n  min-height: 100vh;\n  display: grid;\n  place-items: center;\n  padding: 24px;\n}\n\n.hero-card {\n  width: min(680px, 100%);\n  padding: 40px;\n  border: 1px solid var(--border);\n  border-radius: 28px;\n  background: var(--card);\n  backdrop-filter: blur(12px);\n  box-shadow: var(--shadow);\n}\n\n.eyebrow {\n  display: inline-block;\n  margin-bottom: 12px;\n  font-size: 0.82rem;\n  font-weight: 700;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--accent);\n}\n\nh1 {\n  margin: 0;\n  font-size: clamp(2rem, 5vw, 3.4rem);\n  line-height: 1.05;\n}\n\n.description {\n  margin: 18px 0 0;\n  font-size: 1.05rem;\n  line-height: 1.7;\n  color: var(--muted);\n}\n\n.status-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 16px;\n  margin-top: 28px;\n}\n\n.status-item {\n  padding: 18px;\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.65);\n  border: 1px solid rgba(30, 41, 59, 0.08);\n}\n\n.label {\n  display: block;\n  margin-bottom: 8px;\n  font-size: 0.85rem;\n  color: var(--muted);\n}\n\n.status-item strong {\n  font-size: 1.05rem;\n}\n\n.hint {\n  margin: 28px 0 0;\n  color: var(--muted);\n}\n\ncode {\n  padding: 4px 8px;\n  border-radius: 999px;\n  background: rgba(31, 41, 55, 0.08);\n  font-family: \"Courier New\", monospace;\n}\n\n@media (max-width: 640px) {\n  .hero-card {\n    padding: 28px;\n  }\n\n  .status-grid {\n    grid-template-columns: 1fr;\n  }\n}\n</style>\n"],"mappings":";;EACQA,KAAK,EAAC;AAAW;;EACZA,KAAK,EAAC;AAAW;;EAQnBA,KAAK,EAAC;AAAa;;EACbA,KAAK,EAAC;AAAa;;EAKnBA,KAAK,EAAC;AAAa;;uBAflCC,mBAAA,CAyBO,QAzBPC,UAyBO,GAxBLC,mBAAA,CAuBU,WAvBVC,UAuBU,G,0BAtBRD,mBAAA,CAA4C;IAAtCH,KAAK,EAAC;EAAS,GAAC,iBAAe,Q,0BACrCG,mBAAA,CAAkC,YAA9B,2BAAyB,Q,0BAC7BA,mBAAA,CAGI;IAHDH,KAAK,EAAC;EAAa,GAAC,gJAGvB,QAEAG,mBAAA,CAUM,OAVNE,UAUM,GATJF,mBAAA,CAGU,WAHVG,UAGU,G,0BAFRH,mBAAA,CAAkC;IAA5BH,KAAK,EAAC;EAAO,GAAC,SAAO,QAC3BG,mBAAA,CAAgC,gBAAAI,gBAAA,CAArBC,KAAA,CAAAC,SAAS,M,GAGtBN,mBAAA,CAGU,WAHVO,UAGU,G,0BAFRP,mBAAA,CAAoC;IAA9BH,KAAK,EAAC;EAAO,GAAC,WAAS,QAC7BG,mBAAA,CAAsC,gBAAAI,gBAA